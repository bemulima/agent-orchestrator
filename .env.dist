POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=course_dev_orchestrator
POSTGRES_PORT=5434
HTTP_PORT=8080
SHUTDOWN_TIMEOUT=10

TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=course-dev-orchestrator
TEMPORAL_UI_PORT=8233

# Host directory exposed to the API and worker as /projects. Keep the
# container-side allowlist below aligned with this mount target.
PROJECTS_HOST_ROOT=.
REPOSITORY_ALLOWED_ROOTS=/projects
REPOSITORY_STORAGE_PATH=/data/repositories
WORKTREE_STORAGE_PATH=/data/worktrees
DISCOVERY_MAX_FILES=10000
DISCOVERY_MAX_FILE_BYTES=1048576
DISCOVERY_MAX_TOTAL_BYTES=20971520
DISCOVERY_MAX_DEPTH=24
ONBOARDING_MAX_FILE_BYTES=2097152
ONBOARDING_MAX_TOTAL_BYTES=10485760
ONBOARDING_AUTHOR_NAME=Course Dev Orchestrator
ONBOARDING_AUTHOR_EMAIL=orchestrator@local.invalid

MAX_TASK_ATTEMPTS=3
MAX_REVIEW_ATTEMPTS=2
MAX_REPLANS=2
MAX_PARALLEL_TASKS=3
MAX_REQUIRED_TASK_DEPTH=3

GITLAB_BASE_URL=
GITLAB_TOKEN=
GITLAB_CONTROL_PROJECT=
# Recommended for GitLab 19+: whsec_<base64 key>. Legacy secret remains supported during migration.
GITLAB_WEBHOOK_SIGNING_TOKEN=
GITLAB_WEBHOOK_SECRET=
GITLAB_DRY_RUN=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_CALLBACK_TTL=900

CODEX_RUNNER_COMMAND=node runner/dist/index.js
# By default the worker uses the existing ChatGPT login from local codex-cli.
# Run `codex login` once and `make codex-auth-sync`; no API key is required.
CODEX_MODEL_FAST=
CODEX_MODEL_STANDARD=
CODEX_MODEL_DEEP=
CODEX_MODEL_REVIEW=
