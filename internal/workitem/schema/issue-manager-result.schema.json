{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "issues"],
  "properties": {
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "issues": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_key", "project_id", "issue_type", "title", "body", "labels", "milestone", "assignees", "complexity", "model_profile"],
        "properties": {
          "task_key": {"type": "string", "minLength": 1, "maxLength": 128},
          "project_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "issue_type": {"enum": ["question", "idea", "task", "bug", "research"]},
          "title": {"type": "string", "minLength": 10, "maxLength": 255},
          "body": {"type": "string", "minLength": 100, "maxLength": 65536},
          "labels": {"type": "array", "minItems": 1, "maxItems": 20, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
          "milestone": {"type": "string", "minLength": 1, "maxLength": 255},
          "assignees": {"type": "array", "minItems": 1, "maxItems": 10, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
          "existing_issue": {
            "type": "object",
            "additionalProperties": false,
            "required": ["provider", "project_id", "number"],
            "properties": {
              "provider": {"enum": ["github", "gitlab"]},
              "project_id": {"type": "string", "minLength": 1, "maxLength": 128},
              "number": {"type": "integer", "minimum": 1},
              "url": {"type": "string", "maxLength": 2000}
            }
          },
          "complexity": {"enum": ["low", "medium", "high", "critical"]},
          "model_profile": {"enum": ["fast", "standard", "deep"]}
        }
      }
    }
  }
}
