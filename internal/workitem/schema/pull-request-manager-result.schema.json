{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "pull_request"],
  "properties": {
    "summary": {"type": "string", "minLength": 1, "maxLength": 2000},
    "pull_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "project_id", "title", "body", "labels", "milestone", "assignees", "reviewers", "source_branch", "target_branch", "complexity", "model_profile"],
      "properties": {
        "task_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "project_id": {"type": "string", "minLength": 1, "maxLength": 128},
        "title": {"type": "string", "minLength": 10, "maxLength": 255},
        "body": {"type": "string", "minLength": 100, "maxLength": 65536},
        "labels": {"type": "array", "minItems": 1, "maxItems": 20, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
        "milestone": {"type": "string", "minLength": 1, "maxLength": 255},
        "assignees": {"type": "array", "minItems": 1, "maxItems": 10, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
        "reviewers": {"type": "array", "minItems": 1, "maxItems": 15, "items": {"type": "string", "minLength": 1, "maxLength": 100}},
        "source_branch": {"type": "string", "minLength": 1, "maxLength": 255},
        "target_branch": {"type": "string", "minLength": 1, "maxLength": 255},
        "complexity": {"enum": ["low", "medium", "high", "critical"]},
        "model_profile": {"enum": ["fast", "standard", "deep"]}
      }
    }
  }
}
