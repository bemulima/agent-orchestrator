{
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "files_changed", "checks", "artifacts", "blockers", "required_tasks", "risks", "notes_for_reviewer"],
  "properties": {
    "status": {"type": "string", "enum": ["completed", "blocked", "failed", "changes_required"]},
    "summary": {"type": "string", "minLength": 1, "maxLength": 4000},
    "files_changed": {
      "type": "array",
      "maxItems": 1000,
      "items": {"type": "string", "minLength": 1, "maxLength": 1024}
    },
    "checks": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "details"],
        "properties": {
          "name": {"type": "string", "minLength": 1, "maxLength": 500},
          "status": {"type": "string", "enum": ["passed", "failed", "skipped"]},
          "details": {"type": "string", "maxLength": 8000}
        }
      }
    },
    "artifacts": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "name", "path"],
        "properties": {
          "type": {"type": "string", "minLength": 1, "maxLength": 64},
          "name": {"type": "string", "minLength": 1, "maxLength": 255},
          "path": {"type": "string", "minLength": 1, "maxLength": 1024}
        }
      }
    },
    "blockers": {
      "type": "array",
      "maxItems": 50,
      "items": {"type": "string", "minLength": 1, "maxLength": 4000}
    },
    "required_tasks": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["service", "role", "title", "description", "reason", "acceptance_criteria"],
        "properties": {
          "service": {"type": "string", "minLength": 1, "maxLength": 255},
          "role": {"type": "string", "minLength": 1, "maxLength": 64},
          "title": {"type": "string", "minLength": 1, "maxLength": 255},
          "description": {"type": "string", "minLength": 1, "maxLength": 8000},
          "reason": {"type": "string", "minLength": 1, "maxLength": 4000},
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "items": {"type": "string", "minLength": 1, "maxLength": 2000}
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "maxItems": 50,
      "items": {"type": "string", "minLength": 1, "maxLength": 4000}
    },
    "notes_for_reviewer": {
      "type": "array",
      "maxItems": 50,
      "items": {"type": "string", "minLength": 1, "maxLength": 4000}
    }
  }
}
